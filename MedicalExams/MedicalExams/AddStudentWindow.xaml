<Window x:Class="MedicalExams.AddStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Добавление ученика" 
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#4CAF50" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <TextBlock Text="ДОБАВЛЕНИЕ НОВОГО УЧЕНИКА" 
                       FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="White"/>
        </Border>

        <!-- Форма ввода (с прокруткой) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel>

                <!-- Блок: ФИО -->
                <GroupBox Header="ФИО ученика" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox x:Name="LastNameBox" Grid.Row="0" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
                        <TextBox x:Name="MiddleNameBox" Grid.Row="2" Grid.Column="1" Margin="2" Height="30" Padding="5"/>
                    </Grid>
                </GroupBox>

                <!-- Блок: Основные данные -->
                <GroupBox Header="Основные данные" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата рождения:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <DatePicker x:Name="BirthDatePicker" Grid.Row="0" Grid.Column="1" Margin="2" Height="30" 
                                    SelectedDate="{x:Static sys:DateTime.Now}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Класс:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox x:Name="ClassBox" Grid.Row="1" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Группа здоровья:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox x:Name="HealthGroupCombo" Grid.Row="2" Grid.Column="1" Margin="2" Height="30">
                            <ComboBoxItem Content="1 - здоров" Tag="1"/>
                            <ComboBoxItem Content="2 - незначительные отклонения" Tag="2"/>
                            <ComboBoxItem Content="3 - хронические заболевания в компенсации" Tag="3"/>
                            <ComboBoxItem Content="4 - хронические заболевания в субкомпенсации" Tag="4"/>
                            <ComboBoxItem Content="5 - инвалидность" Tag="5"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- Блок: Контакты -->
                <GroupBox Header="Контактная информация" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center"/>
                        <TextBox x:Name="PhoneBox" Grid.Row="0" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Телефон родителей:" VerticalAlignment="Center"/>
                        <TextBox x:Name="ParentPhoneBox" Grid.Row="1" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Адрес:" VerticalAlignment="Center"/>
                        <TextBox x:Name="AddressBox" Grid.Row="2" Grid.Column="1" Margin="2" Height="30" Padding="5"/>
                    </Grid>
                </GroupBox>

                <!-- Блок: Примечания -->
                <GroupBox Header="Дополнительная информация" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Примечания:" VerticalAlignment="Top"/>
                        <TextBox x:Name="NotesBox" Grid.Row="0" Grid.Column="1" 
                                 Margin="2" Height="80" TextWrapping="Wrap" 
                                 AcceptsReturn="True" Padding="5"/>
                    </Grid>
                </GroupBox>

                <!-- Подсказка -->
                <TextBlock Text="* - обязательные поля" 
                           FontSize="11" FontStyle="Italic" 
                           Foreground="Gray" Margin="5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="120" Height="35" 
                    Margin="5" Click="SaveBtn_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="120" Height="35" 
                    Margin="5" Click="CancelBtn_Click"
                    Background="#F44336" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>