<Window x:Class="MedicalExams.AddExamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавление медосмотра" 
        Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="#2196F3" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <TextBlock x:Name="TitleTextBlock" Text="ДОБАВЛЕНИЕ МЕДОСМОТРА" 
                       FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="White"/>
        </Border>

 
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel>

         
                <GroupBox Header="Ученик" Margin="0,0,0,10" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="StudentInfoTextBlock" 
                                   FontSize="14" FontWeight="Bold" 
                                   Text="Выберите ученика в главном окне"/>
                    </StackPanel>
                </GroupBox>

      
                <GroupBox Header="Данные медосмотра" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата осмотра:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <DatePicker x:Name="ExamDatePicker" Grid.Row="0" Grid.Column="1" Margin="2" Height="30"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Действителен до:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <DatePicker x:Name="ExpiryDatePicker" Grid.Row="1" Grid.Column="1" Margin="2" Height="30"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тип осмотра:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox x:Name="ExamTypeComboBox" Grid.Row="2" Grid.Column="1" Margin="2" Height="30">
                            <ComboBoxItem Content="Ежегодный"/>
                            <ComboBoxItem Content="Перед соревнованиями"/>
                            <ComboBoxItem Content="Дополнительный"/>
                            <ComboBoxItem Content="Первичный"/>
                            <ComboBoxItem Content="Перед поездкой"/>
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Врач:" VerticalAlignment="Center"/>
                        <TextBox x:Name="DoctorTextBox" Grid.Row="3" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Номер документа:" VerticalAlignment="Center"/>
                        <TextBox x:Name="DocumentTextBox" Grid.Row="4" Grid.Column="1" Margin="2" Height="30" Padding="5"/>
                    </Grid>
                </GroupBox>

        
                <GroupBox Header="Заключение" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Заключение:*" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox x:Name="ConclusionTextBox" Grid.Row="0" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ограничения:" VerticalAlignment="Center"/>
                        <TextBox x:Name="RestrictionsTextBox" Grid.Row="1" Grid.Column="1" Margin="2" Height="30" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Допуск:" VerticalAlignment="Center"/>
                        <CheckBox x:Name="AdmittedCheckBox" Grid.Row="2" Grid.Column="1" 
                                  Content="Допущен к занятиям" Margin="2" IsChecked="True"/>
                    </Grid>
                </GroupBox>

      
                <GroupBox Header="Дополнительно" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Примечания:" VerticalAlignment="Top"/>
                        <TextBox x:Name="NotesTextBox" Grid.Row="0" Grid.Column="1" 
                                 Margin="2" Height="60" TextWrapping="Wrap" 
                                 AcceptsReturn="True" Padding="5"/>
                    </Grid>
                </GroupBox>

                <TextBlock Text="* - обязательные поля" 
                           FontSize="11" FontStyle="Italic" 
                           Foreground="Gray" Margin="5"/>
            </StackPanel>
        </ScrollViewer>

 
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Height="35" 
                    Margin="5" Click="SaveButton_Click"
                    Background="#2196F3" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="120" Height="35" 
                    Margin="5" Click="CancelButton_Click"
                    Background="#F44336" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
