<Window x:Class="MedicalExams.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

     
        <Border Grid.Row="0" Background="#FF9800" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <TextBlock Text="ОТЧЕТЫ ПО МЕДОСМОТРАМ" 
                       FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="White"/>
        </Border>

   
        <TabControl Grid.Row="1" Margin="0,0,0,10">
            <!-- Вкладка 1: Статистика -->
            <TabItem Header="Статистика">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <GroupBox Header="Общая статистика" Margin="0,0,0,10" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="TotalStudentsText" Text="Всего учеников: 0" FontSize="14" Margin="5"/>
                                <TextBlock x:Name="TotalExamsText" Text="Всего медосмотров: 0" FontSize="14" Margin="5"/>
                                <TextBlock x:Name="ActiveExamsText" Text="Действующих допусков: 0" FontSize="14" Margin="5"/>
                                <TextBlock x:Name="ExpiringExamsText" Text="Истекают в ближайшие 30 дней: 0" FontSize="14" Margin="5"/>
                                <TextBlock x:Name="ExpiredExamsText" Text="Просрочено: 0" FontSize="14" Margin="5"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Распределение по группам здоровья" Margin="0,0,0,10" Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="HealthGroup1Text" Text="Группа 1: 0" Margin="5"/>
                                <TextBlock x:Name="HealthGroup2Text" Text="Группа 2: 0" Margin="5"/>
                                <TextBlock x:Name="HealthGroup3Text" Text="Группа 3: 0" Margin="5"/>
                                <TextBlock x:Name="HealthGroup4Text" Text="Группа 4: 0" Margin="5"/>
                                <TextBlock x:Name="HealthGroup5Text" Text="Группа 5: 0" Margin="5"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="По классам" Margin="0,0,0,10" Padding="10">
                            <ListBox x:Name="ClassesListBox" Height="150">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

     
            <TabItem Header="Список учеников">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="ExportStudentsBtn" Content="Экспорт в Excel" Width="150" Height="30" Margin="5" Click="ExportStudentsBtn_Click"/>
                        <Button x:Name="PrintStudentsBtn" Content="Печать" Width="100" Height="30" Margin="5" Click="PrintStudentsBtn_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="StudentsReportGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

   
            <TabItem Header="Просроченные справки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="NotifyExpiredBtn" Content="Отправить напоминание" Width="200" Height="30" Margin="5" Click="NotifyExpiredBtn_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ExpiredReportGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>
        </TabControl>

 
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshReportBtn" Content="Обновить" Width="100" Height="35" 
                    Margin="5" Click="RefreshReportBtn_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="CloseBtn" Content="Закрыть" Width="100" Height="35" 
                    Margin="5" Click="CloseBtn_Click"
                    Background="#F44336" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
